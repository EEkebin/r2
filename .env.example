# Discord — from the Developer Portal (https://discord.com/developers/applications)
# Bot -> Token (Reset Token to reveal); DISCORD_CLIENT_ID is the Application ID.
# Also enable: Bot -> Privileged Gateway Intents -> Message Content (for @mention/DM chat).
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Ollama (uncensored vision model with chain-of-thought reasoning)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=huihui_ai/qwen3-vl-abliterated:8b

# SearXNG (self-hosted web search, JSON API)
SEARXNG_URL=http://localhost:8080

# Qwen3-TTS voice-cloning service
TTS_URL=http://localhost:8001

# Only toggle: stream replies into Discord as they generate (true/false)
R2_STREAM=true
